rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // PDF test papers - uploaded by teachers, readable by everyone
    match /test-pdfs/{userId}/{allPaths=**} {
      // Anyone authenticated can read (students need to view/download)
      allow read: if request.auth != null;
      // Only the owner (teacher) can upload
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024  // Max 50MB
                   && request.resource.contentType == 'application/pdf';
      // Owner can delete their own files
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
