rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }
    
    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }
    
    // Check if target user is a student (for teacher management)
    function isTargetStudent(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'student';
    }
    
    // ==================== USERS COLLECTION ====================
    
    match /users/{userId} {
      // All authenticated users can read user profiles (needed for chat participant info)
      allow read: if isAuthenticated();
      
      // Users can only create their own profile
      allow create: if isOwner(userId) && 
        request.resource.data.uid == userId &&
        request.resource.data.email is string &&
        request.resource.data.name is string &&
        request.resource.data.role in ['student', 'teacher'];
      
      // Users can update their own profile, OR teachers can update students
      allow update: if isOwner(userId) || (isTeacher() && isTargetStudent(userId));
      
      // Users can delete their own profile, OR teachers can delete students
      allow delete: if isOwner(userId) || (isTeacher() && isTargetStudent(userId));
    }
    
    // ==================== TESTS COLLECTION ====================
    
    match /tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      // Teachers can fully update; students can update for PDF view tracking
      allow update: if isAuthenticated();
      allow delete: if isTeacher();
    }
    
    // ==================== QUESTIONS COLLECTION ====================
    
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    // ==================== RESULTS COLLECTION ====================
    
    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    // ==================== SUPPORT QUERIES COLLECTION ====================
    
    match /support_queries/{queryId} {
      allow create: if true;
      allow read: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    // ==================== NOTES COLLECTION ====================
    
    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    // ==================== NOTIFICATIONS COLLECTION ====================
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ==================== HOMEWORKS COLLECTION ====================
    
    match /homeworks/{homeworkId} {
      // All authenticated users can read homework
      allow read: if isAuthenticated();
      // Only teachers can create, update, delete homework
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    // ==================== HOMEWORK COMPLETIONS ====================
    
    match /homeworkCompletions/{completionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isTeacher();
    }
    
    // ==================== CREDIT ECONOMY COLLECTIONS ====================
    
    match /wallets/{walletId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isTeacher();
    }
    
    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isTeacher();
    }
    
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    match /userBadges/{userBadgeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isTeacher();
    }
    
    match /premiumTests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isAuthenticated();
      allow delete: if isTeacher();
    }
    
    match /appSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isTeacher();
    }
    
    // ==================== CHAT COLLECTIONS ====================
    
    // Chats - Conversations between students and teachers
    match /chats/{chatId} {
      // Allow getting a specific chat if user is a participant
      allow get: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Allow listing/querying chats - queries filter by participants array or studentId/teacherId
      // The app queries use array-contains on participants, which is secure
      allow list: if isAuthenticated();
      
      // Any authenticated user can create a chat (they must be a participant)
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      // Only participants can update the chat
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Only participants can delete the chat
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }
    
    // Messages - Individual messages in chats
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Presence - Online/offline status
    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // Chat Notifications - New message alerts
    match /chatNotifications/{notificationId} {
      // Allow reading own notifications or listing all (filter client-side)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ==================== COMMUNITY Q&A COLLECTIONS ====================
    
    // Pending Questions (awaiting teacher approval)
    match /pending_questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
    
    // Approved Questions (publicly visible)
    match /approved_questions/{questionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isTeacher();
      
      // Answers subcollection
      match /answers/{answerId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if isTeacher();
      }
    }
    
    // ==================== WEBRTC CALLS COLLECTION ====================
    
    match /calls/{callId} {
      // Allow reading a specific call if user is caller or callee
      allow get: if isAuthenticated() && 
        (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      
      // Allow listing/querying calls
      allow list: if isAuthenticated();
      
      // Authenticated users can create calls (must be the caller)
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      
      // Only caller or callee can update the call
      allow update: if isAuthenticated() && 
        (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      
      // Only caller or callee can delete the call
      allow delete: if isAuthenticated() && 
        (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
    }
    
    // ==================== CLASS CHANGE REQUESTS COLLECTION ====================
    
    match /classChangeRequests/{requestId} {
      // Teachers and the requesting student can read
      allow read: if isAuthenticated();
      // Students can create requests (must be their own)
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      // Students can update their own pending requests; teachers can approve/reject
      allow update: if isAuthenticated() && 
        (resource.data.studentId == request.auth.uid || isTeacher());
      // Only teachers can delete
      allow delete: if isTeacher();
    }
    
    // ==================== MISTAKE BUCKET COLLECTION (Practice Mode) ====================
    
    match /mistakeBucket/{itemId} {
      // Students can read their own mistakes
      allow read: if isAuthenticated();
      // Students can create mistakes (auto-saved after test submission)
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      // Students can update their own mistakes (record attempts)
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      // Teachers can manage all; students can delete their own
      allow delete: if isTeacher() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
    }
    
    // ==================== DAILY QUIZ RESULTS COLLECTION ====================
    
    match /dailyQuizResults/{resultId} {
      // Students can read their own results; teachers can read all
      allow read: if isAuthenticated();
      // Students can create their own results
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      // No updates allowed (immutable once submitted)
      allow update: if false;
      // Teachers can delete
      allow delete: if isTeacher();
    }
    // ==================== FEE STRUCTURE REQUESTS ====================
    
    match /feeRequests/{requestId} {
      // Anyone can read (for checking own request status)
      allow read: if true;
      // Anyone can create a request (no login required)
      allow create: if true;
      // Only teachers can approve/reject
      allow update: if isTeacher();
      // Only teachers can delete
      allow delete: if isTeacher();
    }
    
    // ==================== FEE STRUCTURE VISIBILITY SETTINGS ====================
    
    match /settings/{settingId} {
      // Anyone can read settings (to check if fee structure is visible)
      allow read: if true;
      // Only teachers can update settings
      allow write: if isTeacher();
    }
    
    // ==================== EVALUATION DRAFTS COLLECTION ====================
    
    match /evaluationDrafts/{draftId} {
      // Only teachers can read evaluation drafts
      allow read: if isTeacher();
      // Only teachers can create and update drafts
      allow create, update: if isTeacher();
      // Only teachers can delete drafts
      allow delete: if isTeacher();
    }
    
    // ==================== TEST SESSIONS COLLECTION (Anti-Cheat) ====================
    
    match /testSessions/{sessionId} {
      // Students can read their own sessions; teachers can read all
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isTeacher());
      // Students can create sessions for themselves only
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // Students can update their own in-progress sessions only
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // Only teachers can delete sessions (for admin resets)
      allow delete: if isTeacher();
    }
  }
}
